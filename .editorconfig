root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown — keep PhpStorm / IDE soft-wrap on display, never hard-wrap on save.
# Hard wrapping breaks line-anchored tooling (humanize-article, review-article, diffs).
[*.md]
max_line_length = off
trim_trailing_whitespace = false
